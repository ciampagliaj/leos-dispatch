rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Leo's Receipt Tracker has no Firebase Auth login — keep this open
    // so the existing live app (ciampagliaj.github.io/leos-pwa) keeps working.
    match /receipts/{receiptId} {
      allow read, write: if true;
    }

    // Leo's Dispatch collections — require Google sign-in via Firebase Auth.
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    // Read is public so Leo's Receipt Tracker (no Firebase Auth) can show the
    // shared customer list and autocomplete; only Dispatch (signed-in) can write.
    match /customers/{customerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /jobs/{jobId} {
      allow read, write: if request.auth != null;
    }
    match /quotes/{quoteId} {
      allow read, write: if request.auth != null;
    }
    match /invoices/{invoiceId} {
      allow read, write: if request.auth != null;
    }
    match /mileageLog/{logId} {
      allow read, write: if request.auth != null;
    }
    match /inventory/{itemId} {
      allow read, write: if request.auth != null;
    }
    match /priceList/{itemId} {
      allow read, write: if request.auth != null;
    }
    match /truckLog/{logId} {
      allow read, write: if request.auth != null;
    }
  }
}
